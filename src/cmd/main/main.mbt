///|
fn cmd_build(args : Array[String]) -> Unit {
  let mut file = ""
  let mut no_header = false
  let mut to_stdout = false
  let mut strict = true
  let mut cjs = false
  let mut i = 0
  while i < args.length() {
    if args[i] == "--no-header" {
      no_header = true
    } else if args[i] == "--stdout" {
      to_stdout = true
    } else if args[i] == "--strict" {
      if i + 1 < args.length() &&
        (args[i + 1] == "true" || args[i + 1] == "false") {
        i += 1
        strict = args[i] == "true"
      } else {
        strict = true
      }
    } else if args[i] == "--type" {
      if i + 1 < args.length() {
        i += 1
        cjs = args[i] == "commonjs"
      }
    } else {
      file = args[i]
    }
    i += 1
  }
  if file == "" {
    println("Error: no input file specified")
    println("Usage: purus build <file.purus|.cpurus|.mpurus>")
    return
  }
  // Read source file
  let src = @fs.read_file_to_string(file) catch {
    @fs.IOError(msg) => {
      println("Error: cannot read file '" + file + "': " + msg)
      return
    }
  }
  // Compile
  let tokens = @lexer.Lexer::new(src).tokenize()
  // Extract shebang if present
  let mut shebang = ""
  let mut tok_start = 0
  if tokens.length() > 0 {
    match tokens[0].kind {
      @lexer.Shebang(s) => {
        shebang = s
        tok_start = 1
        // Also skip the Newline token after shebang
        if tok_start < tokens.length() {
          match tokens[tok_start].kind {
            @lexer.Newline => tok_start = tok_start + 1
            _ => ()
          }
        }
      }
      _ => ()
    }
  }
  // Filter tokens for parser (skip shebang + its newline)
  let filtered : Array[@lexer.Token] = []
  let mut fi = tok_start
  while fi < tokens.length() {
    filtered.push(tokens[fi])
    fi += 1
  }
  let parser = @parser.Parser::new(filtered)
  let stmts = parser.parse()
  if parser.errors.length() > 0 {
    for msg in parser.errors {
      println("Error: " + msg)
    }
    @sys.exit(1)
  }
  let header = if no_header {
    ""
  } else {
    "// Generated by Purus __PURUS_VERSION__"
  }
  let js = @codegen.JsCodegen::new(cjs~).generate(
    stmts,
    header~,
    shebang~,
    strict~,
  )
  if to_stdout {
    println(js)
    return
  }
  // Write output to file
  let base_and_ext = if file.has_suffix(".cpurus") {
    let chars = file.to_array()
    let buf = StringBuilder::new()
    let mut i = 0
    while i < chars.length() - 7 {
      buf.write_char(chars[i])
      i += 1
    }
    (buf.to_string(), ".cjs")
  } else if file.has_suffix(".mpurus") {
    let chars = file.to_array()
    let buf = StringBuilder::new()
    let mut i = 0
    while i < chars.length() - 7 {
      buf.write_char(chars[i])
      i += 1
    }
    (buf.to_string(), ".mjs")
  } else if file.has_suffix(".purus") {
    let chars = file.to_array()
    let buf = StringBuilder::new()
    let mut i = 0
    while i < chars.length() - 6 {
      buf.write_char(chars[i])
      i += 1
    }
    (buf.to_string(), ".js")
  } else {
    (file, ".js")
  }
  let out_file = base_and_ext.0 + base_and_ext.1
  @fs.write_string_to_file(out_file, js) catch {
    @fs.IOError(msg) => {
      println("Error: cannot write file '" + out_file + "': " + msg)
      return
    }
  }
  println("Compiled " + file + " -> " + out_file)
}

///|
fn cmd_check(file : String) -> Unit {
  if file == "" {
    println("Error: no input file specified")
    println("Usage: purus check <file.purus|.cpurus|.mpurus>")
    return
  }
  let src = @fs.read_file_to_string(file) catch {
    @fs.IOError(msg) => {
      println("Error: cannot read file '" + file + "': " + msg)
      return
    }
  }
  let tokens = @lexer.Lexer::new(src).tokenize()
  let parser = @parser.Parser::new(tokens)
  let _stmts = parser.parse()
  if parser.errors.length() > 0 {
    for msg in parser.errors {
      println("Error: " + msg)
    }
    @sys.exit(1)
  }
  println("OK: " + file)
}

///|
fn main {
  let args = @sys.get_cli_args()
  // args[0] is the program name
  if args.length() < 2 {
    return
  }
  let cmd = args[1]
  match cmd {
    "build" | "compile" => cmd_build(args[2:].to_owned())
    "check" => {
      let file = if args.length() > 2 { args[2] } else { "" }
      cmd_check(file)
    }
    _ => println("Unknown command: " + cmd)
  }
}
