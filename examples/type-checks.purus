-- Type Checking

const value be 42

-- Type check with typeof and eq
if typeof value eq //;number;//
  console.log[//;it's a number;//]

-- Type check with typeof
if typeof value eq //;string;//
  console.log[//;it's a string;//]

-- instanceof
const date be new Date[]
if date instanceof Date
  console.log[//;it's a Date;//]

-- typeof operator
const t be typeof value
console.log[t]

-- Type cast (erased in output)
const num be value as Number
