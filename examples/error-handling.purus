-- Error Handling

use p-json as j

-- Try-catch
try
  const data be j.parse[//;invalid;//]
catch err
  console.error[//;Parse failed:;//; err]

-- Try-catch-finally
try
  const res be await fetch[//;https://api.example.com/data;//]
catch err
  console.error[err]
finally
  console.log[//;done;//]

-- Throw
fn validate value
  unless value
    throw new Error[//;Invalid value;//]
  return value

-- Try as expression
const result be try
  j.parse[//;["key": "value"];//]
catch e
  null
